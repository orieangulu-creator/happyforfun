# 生产环境变量（在 Vercel 项目 Settings → Environment Variables 中配置）
# ⚠️ 这些值【只存服务端】，绝不写进前端代码、绝不入 git。

# —— 大模型供应商（默认 deepseek，可改 anthropic）——
LLM_PROVIDER=deepseek

# DeepSeek key（默认供应商）—— 在 platform.deepseek.com 创建；唯一机密，永不下发浏览器
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 若改用 Claude：把 LLM_PROVIDER 设为 anthropic，并改填下面这个
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 模型（可选）：deepseek 默认 deepseek-chat；anthropic 默认 claude-opus-4-8
# LLM_MODEL=deepseek-chat

# 访问码 —— 用户需输入此码才能调用生成接口（防止端点被陌生人刷额度）
ACCESS_CODE=set-a-strong-shared-code

# 域名锁 —— 只允许这些来源调用 /api（逗号分隔）。建议设为你的正式域名。
# 留空则退化为“仅同主机”校验。
ALLOWED_ORIGIN=https://your-app.vercel.app

# 每 IP 每分钟最大请求数（可选，默认 15）
RATE_LIMIT_PER_MIN=15
